{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "clasp: watch push on save",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\watch-push.ps1"
      ],
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "clasp: push once",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\push.ps1",
        "-Note",
        "${input:pushNote}"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "clasp: deploy update existing",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\update-version.ps1",
        "-Note",
        "${input:deployNote}"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "clasp: deployment list",
      "type": "shell",
      "command": "clasp",
      "args": [
        "list-deployments"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "clasp: open Apps Script",
      "type": "shell",
      "command": "clasp",
      "args": [
        "open-script"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "pushNote",
      "type": "promptString",
      "description": "這次測試版具體改了什麼？留空則使用自動摘要",
      "default": ""
    },
    {
      "id": "deployNote",
      "type": "promptString",
      "description": "這次正式部署具體改了什麼？留空則使用自動摘要",
      "default": ""
    }
  ]
}
